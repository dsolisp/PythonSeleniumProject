{
  "consumer": {
    "name": "PythonSeleniumProject"
  },
  "interactions": [
    {
      "description": "a request for post 1",
      "pending": false,
      "providerStates": [
        {
          "name": "a post with id 1 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/posts/1"
      },
      "response": {
        "body": {
          "content": {
            "body": "world",
            "id": 1,
            "title": "hello",
            "userId": 1
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json; charset=utf-8"
          ]
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "JSONPlaceholder"
  }
}