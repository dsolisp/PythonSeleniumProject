{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "assignees": [],
  "schedule": ["every weekend"],
  "prConcurrentLimit": 5,
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",

  "packageRules": [
    {
      "description": "Python dependencies — group minor+patch for auto-merge",
      "matchManagers": ["pip_requirements", "pip-compile", "pipenv", "pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Python dependencies (minor+patch)",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Python major updates — require manual review",
      "matchManagers": ["pip_requirements", "pip-compile", "pipenv", "pep621"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"]
    },
    {
      "description": "GitHub Actions — auto-merge patch",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "GitHub Actions"
    },
    {
      "description": "Security updates — immediate, no schedule",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "automerge": false,
      "labels": ["dependencies", "security"],
      "prPriority": 10
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "osvVulnerabilityAlerts": true
}
