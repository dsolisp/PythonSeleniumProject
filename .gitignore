# ═══════════════════════════════════════════════════════════════════════════════
# PythonSeleniumProject .gitignore
# 7 Laws of QA Automation — Law 3: Repeatability (no local state committed)
# ADR-009: Auth state must never be committed
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python bytecode & cache ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
venv-enhanced/
.venv/
.venv-ci/
env/
ENV/

# ── Test outputs ───────────────────────────────────────────────────────────────
test-results/
test_reports/
allure-results/
allure-report/
playwright-report/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Screenshots & visual diffs ─────────────────────────────────────────────────
screenshots/
screenshots_diff/
custom_screenshots/
# NOTE: Visual baselines must be committed for true regression testing.
# Generated media is expected to live under the ignored output folders above.

# ── Reports ───────────────────────────────────────────────────────────────────
reports/
custom_reports/
custom_logs/

# ── Auth state (ADR-009) ──────────────────────────────────────────────────────
.auth/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Data results ──────────────────────────────────────────────────────────────
data/results/

# ── Database artifacts ────────────────────────────────────────────────────────
*.db
*.sqlite
.test-results.db

# ── Legacy contract-testing outputs (Pact removed) ────────────────────────────
pacts/

# ── Build & distribution ──────────────────────────────────────────────────────
dist/
coverage/
*.zip
*.exe
drivers/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
data/.DS_Store
.Spotlight-V100
.Trashes
Thumbs.db

# ── IDE files ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
